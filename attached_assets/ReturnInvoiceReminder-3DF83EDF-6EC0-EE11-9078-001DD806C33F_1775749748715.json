                      "emailMessage/Body": "<p>Invoice Number @{items('Apply_to_each')?['Title']} has been in the return queue for @{div(\r\n    sub(\r\n        ticks(\r\n            formatDateTime(convertTimeZone(utcNow(), 'UTC', 'Pacific Standard Time'),'yyyy-MM-dd'))\r\n        ,\r\n        ticks(\r\n            formatDateTime(items('Apply_to_each')?['InvoiceReturnDate'],'yyyy-MM-dd'))\r\n        )\r\n,864000000000)} days.<br>\n<br>\nPlease work together to get this invoice processed.<br>\n<br>\nUse this link to edit the Invoice: <a href=@{parameters('InvoiceReturnURL (invoicet_InvoiceReturnURL)')}?screen=Edit&SubID=@{items('Apply_to_each')?['ID']}>;Edit</a></p>",
                      "emailMessage/Importance": "Normal"
                    },
                    "authentication": "@parameters('$authentication')"
                  }
                }
              },
              "runAfter": {
                "Compose": [
                  "Succeeded"
                ]
              },
              "else": {
                "actions": {
                  "Condition_3": {
                    "actions": {
                      "Send_an_email_(V2)_3": {
                        "runAfter": {},
                        "metadata": {
                          "operationMetadataId": "1b263330-543e-49ed-bbf0-56df8e9f9fc8"
                        },
                        "type": "OpenApiConnection",
                        "inputs": {
                          "host": {
                            "connectionName": "shared_office365_1",
                            "operationId": "SendEmailV2",
                            "apiId": "/providers/Microsoft.PowerApps/apis/shared_office365"
                          },
                          "parameters": {
                            "emailMessage/To": "@{items('Apply_to_each')?['Author/Email']};austin.friello@cdph.ca.gov",
                            "emailMessage/Subject": "Return Invoice Reminder: @{div(\r\n    sub(\r\n        ticks(\r\n            formatDateTime(convertTimeZone(utcNow(), 'UTC', 'Pacific Standard Time'),'yyyy-MM-dd'))\r\n        ,\r\n        ticks(\r\n            formatDateTime(items('Apply_to_each')?['InvoiceReturnDate'],'yyyy-MM-dd'))\r\n        )\r\n,864000000000)} Days",
                            "emailMessage/Body": "<p>Invoice Number @{items('Apply_to_each')?['Title']} has been in the return queue for @{div(\r\n    sub(\r\n        ticks(\r\n            formatDateTime(convertTimeZone(utcNow(), 'UTC', 'Pacific Standard Time'),'yyyy-MM-dd'))\r\n        ,\r\n        ticks(\r\n            formatDateTime(items('Apply_to_each')?['InvoiceReturnDate'],'yyyy-MM-dd'))\r\n        )\r\n,864000000000)} days.<br>\n<br>\nPlease work together to get this invoice processed.<br>\n<br>\nUse this link to edit the Invoice: <a href=@{parameters('InvoiceReturnURL (invoicet_InvoiceReturnURL)')}?screen=Edit&SubID=@{items('Apply_to_each')?['ID']}>;Edit</a></p>",
                            "emailMessage/Importance": "Normal"
                          },
                          "authentication": "@parameters('$authentication')"
                        }
                      }
                    },
                    "runAfter": {},
                    "else": {
                      "actions": {
                        "Condition": {
                          "actions": {
                            "Send_an_email_(V2)_5": {
                              "runAfter": {},
                              "metadata": {
                                "operationMetadataId": "1b263330-543e-49ed-bbf0-56df8e9f9fc8"
                              },
                              "type": "OpenApiConnection",
                              "inputs": {
                                "host": {
                                  "connectionName": "shared_office365_1",
                                  "operationId": "SendEmailV2",
                                  "apiId": "/providers/Microsoft.PowerApps/apis/shared_office365"
                                },
                                "parameters": {
                                  "emailMessage/To": "@{items('Apply_to_each')?['Author/Email']};Teresa.Medley@cdph.ca.gov",
                                  "emailMessage/Subject": "Return Invoice Reminder: @{div(sub(ticks(formatDateTime(convertTimeZone(utcNow(), 'UTC', 'Pacific Standard Time'), 'yyyy-MM-dd')), ticks(formatDateTime(items('Apply_to_each')?['InvoiceReturnDate'], 'yyyy-MM-dd'))), 864000000000)} Days",
                                  "emailMessage/Body": "<p>Invoice Number @{items('Apply_to_each')?['Title']} has been in the return queue for @{div(sub(ticks(formatDateTime(convertTimeZone(utcNow(), 'UTC', 'Pacific Standard Time'), 'yyyy-MM-dd')), ticks(formatDateTime(items('Apply_to_each')?['InvoiceReturnDate'], 'yyyy-MM-dd'))), 864000000000)} days.<br>\n<br>\nPlease work together to get this invoice processed.<br>\n<br>\nUse this link to edit the Invoice: <a href=@{parameters('InvoiceReturnURL (invoicet_InvoiceReturnURL)')}?screen=Edit&SubID=@{items('Apply_to_each')?['ID']}>;Edit</a></p>",
                                  "emailMessage/Importance": "Normal"
                                },
                                "authentication": "@parameters('$authentication')"
                              }
                            }
                          },
                          "runAfter": {},
                          "else": {
                            "actions": {
                              "Send_an_email_(V2)_4": {
                                "runAfter": {},
                                "metadata": {
                                  "operationMetadataId": "1b263330-543e-49ed-bbf0-56df8e9f9fc8"
                                },
                                "type": "OpenApiConnection",
                                "inputs": {
                                  "host": {
                                    "connectionName": "shared_office365_1",
                                    "operationId": "SendEmailV2",
                                    "apiId": "/providers/Microsoft.PowerApps/apis/shared_office365"
                                  },
                                  "parameters": {
                                    "emailMessage/To": "@{items('Apply_to_each')?['Author/Email']};@{outputs('Compose')}",
                                    "emailMessage/Subject": "Return Invoice Reminder: @{div(sub(ticks(formatDateTime(convertTimeZone(utcNow(), 'UTC', 'Pacific Standard Time'), 'yyyy-MM-dd')), ticks(formatDateTime(items('Apply_to_each')?['InvoiceReturnDate'], 'yyyy-MM-dd'))), 864000000000)} Days",
                                    "emailMessage/Body": "<p>Invoice Number @{items('Apply_to_each')?['Title']} has been in the return queue for @{div(sub(ticks(formatDateTime(convertTimeZone(utcNow(), 'UTC', 'Pacific Standard Time'), 'yyyy-MM-dd')), ticks(formatDateTime(items('Apply_to_each')?['InvoiceReturnDate'], 'yyyy-MM-dd'))), 864000000000)} days.<br>\n<br>\nPlease work together to get this invoice processed.<br>\n<br>\nUse this link to edit the Invoice: <a href=@{parameters('InvoiceReturnURL (invoicet_InvoiceReturnURL)')}?screen=Edit&SubID=@{items('Apply_to_each')?['ID']}>;Edit</a></p>",
                                    "emailMessage/Importance": "Normal"
                                  },
                                  "authentication": "@parameters('$authentication')"
                                }
                              }
                            }
                          },
                          "expression": {
                            "equals": [
                              "@items('Apply_to_each')?['StaffName/Value']",
                              "T.J. Medley"
                            ]
                          },
                          "metadata": {
                            "operationMetadataId": "ca12013e-0561-46ac-9125-853cad1d6456"
                          },
                          "type": "If"
                        }
                      }
                    },
                    "expression": {
                      "equals": [
                        "@outputs('Compose')",
