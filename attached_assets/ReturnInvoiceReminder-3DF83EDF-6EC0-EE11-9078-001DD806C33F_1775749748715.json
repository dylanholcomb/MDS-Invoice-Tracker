                      ]
                    },
                    "metadata": {
                      "operationMetadataId": "9b0fa8e5-776c-4dba-9ed6-c00f1ec31d87"
                    },
                    "type": "If"
                  }
                }
              },
              "expression": {
                "equals": [
                  "@outputs('Compose')",
                  "COVID-19@cdph.ca.gov"
                ]
              },
              "metadata": {
                "operationMetadataId": "6bb0413d-d2b4-4f77-889d-3263f1353434"
              },
              "type": "If"
            }
          },
          "runAfter": {
            "Get_items_2": [
              "Succeeded"
            ]
          },
          "metadata": {
            "operationMetadataId": "73ecebd1-5621-4528-a646-f5178e813b94"
          },
          "type": "Foreach"
        }
      }
    },
    "templateName": ""
