      "actions": {
        "Get_items_2": {
          "runAfter": {},
          "metadata": {
            "operationMetadataId": "9677cb6b-738e-4cae-a74b-8cd7793cb042"
          },
          "type": "OpenApiConnection",
          "inputs": {
            "host": {
              "connectionName": "shared_sharepointonline",
              "operationId": "GetItems",
              "apiId": "/providers/Microsoft.PowerApps/apis/shared_sharepointonline"
            },
            "parameters": {
              "dataset": "@parameters('InvoiceTrackingSite (invoicet_InvoiceTrackingSite)')",
              "table": "@parameters('InvoiceTrackingInvoices (invoicet_InvoiceTrackingInvoices)')",
              "$filter": "(InvoiceStatus eq 'Returned to Submitter') and (((InvoiceReturnDate lt '@{formatDateTime(addDays(convertTimeZone(utcNow(),'UTC','Pacific Standard Time','D'),-4),'MM/dd/yyyy')}') and (InvoiceReturnDate gt '@{formatDateTime(addDays(convertTimeZone(utcNow(),'UTC','Pacific Standard Time','D'),-6),'MM/dd/yyyy')}')) or ((InvoiceReturnDate lt '@{formatDateTime(addDays(convertTimeZone(utcNow(),'UTC','Pacific Standard Time','D'),-9),'MM/dd/yyyy')}') and (InvoiceReturnDate gt '@{formatDateTime(addDays(convertTimeZone(utcNow(),'UTC','Pacific Standard Time','D'),-11),'MM/dd/yyyy')}')))"
            },
            "authentication": "@parameters('$authentication')"
          }
        },
        "Apply_to_each": {
          "foreach": "@outputs('Get_items_2')?['body/value']",
          "actions": {
            "Compose": {
              "runAfter": {},
              "metadata": {
                "operationMetadataId": "52232b9c-e7ec-407e-a1cf-afb90d0a0882"
              },
              "type": "Compose",
              "inputs": "@concat(Replace(items('Apply_to_each')?['StaffName/Value'], ' ', '.'), '@cdph.ca.gov')"
            },
            "Condition_2": {
              "actions": {
                "Send_an_email_(V2)": {
                  "runAfter": {},
                  "metadata": {
                    "operationMetadataId": "1b263330-543e-49ed-bbf0-56df8e9f9fc8"
