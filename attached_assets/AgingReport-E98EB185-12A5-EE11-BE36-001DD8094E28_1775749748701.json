                    "01OQG3RMG5736ADX7HCRDIHTWTHREDY7SO": "/Aged_Invoice_Report.xlsx"
                  },
                  "type": "OpenApiConnection",
                  "inputs": {
                    "host": {
                      "connectionName": "shared_excelonlinebusiness",
                      "operationId": "DeleteItem",
                      "apiId": "/providers/Microsoft.PowerApps/apis/shared_excelonlinebusiness"
                    },
                    "parameters": {
                      "source": "@parameters('InvoiceTrackingSite (invoicet_InvoiceTrackingSite)')",
                      "drive": "b!7B1N0IuDqESEs5NBBEdacEYOdyx9AjlCq7mlnSnqG1gQrZ41IjENQJOntdVrpmwJ",
                      "file": "01OQG3RMG5736ADX7HCRDIHTWTHREDY7SO",
                      "table": "{D69143D1-2C89-44B6-A00C-C6AE1A94F748}",
                      "idColumn": "Submission ID",
                      "id": "@items('Apply_to_each_2')?['Submission ID']"
                    },
                    "authentication": "@parameters('$authentication')"
                  }
                }
              },
              "runAfter": {
                "List_rows_present_in_a_table": [
                  "Succeeded"
                ]
              },
              "metadata": {
                "operationMetadataId": "e0b30f33-5a59-48a1-b025-b66a6f1c297b"
              },
              "type": "Foreach"
            },
            "Get_items": {
              "runAfter": {
                "Apply_to_each_2": [
                  "Succeeded"
                ]
              },
              "metadata": {
                "operationMetadataId": "9f22b1ad-5d06-4241-a4b1-b268d5e6473f"
              },
              "type": "OpenApiConnection",
              "inputs": {
                "host": {
                  "connectionName": "shared_sharepointonline",
                  "operationId": "GetItems",
                  "apiId": "/providers/Microsoft.PowerApps/apis/shared_sharepointonline"
                },
                "parameters": {
                  "dataset": "@parameters('InvoiceTrackingSite (invoicet_InvoiceTrackingSite)')",
                  "table": "@parameters('InvoiceTrackingInvoices (invoicet_InvoiceTrackingInvoices)')",
                  "$filter": "((InvoiceStatus eq 'Awaiting Processing') or (InvoiceStatus eq 'Returned to Submitter') or (InvoiceStatus eq 'Duplicate')) and (Modified lt '@{formatDateTime(addDays(convertTimeZone(utcNow(),'UTC','Pacific Standard Time','D'),-10),'MM/dd/yyyy')}')",
                  "$orderby": "Modified asc"
                },
                "authentication": "@parameters('$authentication')"
              }
            },
            "Apply_to_each": {
              "foreach": "@outputs('Get_items')?['body/value']",
              "actions": {
                "clean_status_notes": {
                  "runAfter": {},
                  "metadata": {
                    "operationMetadataId": "18fb474f-faf8-4108-98d1-fd66e23af547"
                  },
                  "type": "OpenApiConnection",
                  "inputs": {
                    "host": {
                      "connectionName": "shared_conversionservice",
                      "operationId": "HtmlToText",
                      "apiId": "/providers/Microsoft.PowerApps/apis/shared_conversionservice"
                    },
                    "parameters": {
                      "Content": "<p>@{items('Apply_to_each')?['StatusNotes']}</p>"
                    },
                    "authentication": "@parameters('$authentication')"
                  }
                },
                "Add_a_row_into_a_table": {
                  "runAfter": {
                    "clean_status_notes": [
                      "Succeeded"
                    ]
                  },
                  "metadata": {
                    "01PGYE442AYCQD3TYIABC3KUWMFGM34Y5B": "/workingfiles/agingreport.xlsx",
                    "operationMetadataId": "8efd06ae-1ff0-4cfa-8c43-150ce2843158",
                    "tableId": "{D69143D1-2C89-44B6-A00C-C6AE1A94F748}",
                    "01OQG3RMG5736ADX7HCRDIHTWTHREDY7SO": "/Aged_Invoice_Report.xlsx"
                  },
                  "type": "OpenApiConnection",
                  "inputs": {
                    "host": {
                      "connectionName": "shared_excelonlinebusiness",
                      "operationId": "AddRowV2",
                      "apiId": "/providers/Microsoft.PowerApps/apis/shared_excelonlinebusiness"
                    },
                    "parameters": {
                      "source": "@parameters('InvoiceTrackingSite (invoicet_InvoiceTrackingSite)')",
                      "drive": "b!7B1N0IuDqESEs5NBBEdacEYOdyx9AjlCq7mlnSnqG1gQrZ41IjENQJOntdVrpmwJ",
                      "file": "01OQG3RMG5736ADX7HCRDIHTWTHREDY7SO",
                      "table": "{D69143D1-2C89-44B6-A00C-C6AE1A94F748}",
                      "dateTimeFormat": "ISO 8601",
                      "item/Unit": "@items('Apply_to_each')?['Unit']",
                      "item/Supervisor": "@items('Apply_to_each')?['Supervisor']",
                      "item/Staff Name": "@items('Apply_to_each')?['StaffName/Value']",
                      "item/Expedite~1Special Handling": "@items('Apply_to_each')?['Expedite']",
                      "item/Invoice Status": "@items('Apply_to_each')?['InvoiceStatus/Value']",
                      "item/Invoice Age": "@{div(\r\n    sub(\r\n        ticks(\r\n            formatDateTime(utcNow(),'yyyy-MM-dd'))\r\n        ,\r\n        ticks(\r\n            formatDateTime(items('Apply_to_each')?['AccountingReceived'],'yyyy-MM-dd'))\r\n        )\r\n,864000000000)} days old",
                      "item/Acctg Received": "@formatDateTime(convertTimeZone(items('Apply_to_each')?['AccountingReceived'],'UTC','Pacific Standard Time'),'MM/dd/yyyy')",
                      "item/Modified Age": "@{div(\r\n    sub(\r\n        ticks(\r\n            formatDateTime(utcNow(),'yyyy-MM-dd'))\r\n        ,\r\n        ticks(\r\n            formatDateTime(items('Apply_to_each')?['Modified'],'yyyy-MM-dd'))\r\n        )\r\n,864000000000)} days since modified",
                      "item/Last Modified date_x003a_": "@if(empty(items('Apply_to_each')?['Modified']),'',\r\nformatDateTime(convertTimeZone(items('Apply_to_each')?['Modified'],'UTC','Pacific Standard Time'),'MM/dd/yyyy'))",
                      "item/Last Modified By": "@items('Apply_to_each')?['Editor/Email']",
                      "item/Invoice Date": "@items('Apply_to_each')?['InvoiceDate']",
                      "item/Invoice Number": "@items('Apply_to_each')?['Title']",
                      "item/Invoice Amount": "@items('Apply_to_each')?['InvoiceAmount']",
                      "item/Supplier Name": "@items('Apply_to_each')?['VendorName']",
                      "item/Payment Data": "@body('clean_status_notes')",
                      "item/CDO Received": "@formatDateTime(items('Apply_to_each')?['ProgramRecieved'],'MM/dd/yyyy')",
                      "item/Last User Edit Date": "@if(empty(items('Apply_to_each')?['InvoiceEditDate']),'null',formatDateTime(items('Apply_to_each')?['InvoiceEditDate'],'MM/dd/yyyy'))",
                      "item/Submission Notes": "@items('Apply_to_each')?['SubmissionNotes']",
                      "item/Submission ID": "@items('Apply_to_each')?['ID']",
                      "item/Status Notes": "@body('clean_status_notes')"
                    },
                    "authentication": "@parameters('$authentication')"
                  }
                }
              },
              "runAfter": {
                "Get_items": [
                  "Succeeded"
                ]
              },
              "metadata": {
                "operationMetadataId": "f858ab9f-8716-4d88-b4fe-12a940ac319d"
              },
              "type": "Foreach"
