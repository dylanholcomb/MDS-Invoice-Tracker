                  "unit": "Minute"
                }
              }
            },
            "Send_an_email_(V2)": {
              "runAfter": {
                "Get_file_content_using_path": [
                  "Succeeded"
                ]
              },
              "metadata": {
                "operationMetadataId": "e750fc69-6ac5-4349-a342-265ec70b802f"
              },
              "type": "OpenApiConnection",
              "inputs": {
                "host": {
                  "connectionName": "shared_office365",
                  "operationId": "SendEmailV2",
                  "apiId": "/providers/Microsoft.PowerApps/apis/shared_office365"
                },
                "parameters": {
                  "emailMessage/To": "Helen.Vo@cdph.ca.gov;Latifah.LaFreniere@cdph.ca.gov;Arveen.Deo@cdph.ca.gov;Austin.Friello@cdph.ca.gov;Doina.Fusneica@cdph.ca.gov;FMBATERS@cdph.ca.gov",
                  "emailMessage/Subject": "Aging report for Invoice Tracking",
                  "emailMessage/Body": "<p>Attached is the aging report for @{formatDateTime(utcNow(),'MM/dd/yyyy')}.</p>",
                  "emailMessage/Attachments": [
                    {
                      "Name": "Aged_Invoice_Report.xlsx",
                      "ContentBytes": "@body('Get_file_content_using_path')"
                    }
                  ],
                  "emailMessage/Importance": "Normal"
                },
                "authentication": "@parameters('$authentication')"
              }
            },
            "Get_file_content_using_path": {
              "runAfter": {
                "Delay": [
                  "Succeeded"
                ]
              },
              "metadata": {
                "operationMetadataId": "84c49042-5faa-4db4-8dfe-6e8628611b1e"
              },
              "type": "OpenApiConnection",
              "inputs": {
                "host": {
                  "connectionName": "shared_sharepointonline",
                  "operationId": "GetFileContentByPath",
                  "apiId": "/providers/Microsoft.PowerApps/apis/shared_sharepointonline"
                },
                "parameters": {
                  "dataset": "@parameters('InvoiceTrackingSite (invoicet_InvoiceTrackingSite)')",
                  "path": "/ProcessDocuments/Aged_Invoice_Report.xlsx",
                  "inferContentType": true
                },
                "authentication": "@parameters('$authentication')"
              }
            }
          },
          "runAfter": {},
          "expression": {
            "equals": [
              "@contains('12345', string(dayOfWeek(addHours(utcNow(), -8))))",
              true
            ]
          },
          "metadata": {
            "operationMetadataId": "e62fc4e1-22ba-48c9-85f6-5e276b792040"
          },
          "type": "If"
        }
      }
    },
