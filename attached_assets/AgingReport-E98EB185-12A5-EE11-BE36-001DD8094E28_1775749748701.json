                "authentication": "@parameters('$authentication')"
              }
            },
            "Apply_to_each_2": {
              "foreach": "@outputs('List_rows_present_in_a_table')?['body/value']",
              "actions": {
                "Delete_a_row": {
                  "runAfter": {},
                  "metadata": {
                    "01PGYE442AYCQD3TYIABC3KUWMFGM34Y5B": "/workingfiles/agingreport.xlsx",
                    "operationMetadataId": "0892c0bc-49ce-4760-a387-4c9daa3f511b",
                    "tableId": "{D69143D1-2C89-44B6-A00C-C6AE1A94F748}",
